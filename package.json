{
  "name": "@termlnk/termlnk",
  "type": "module",
  "version": "0.0.2",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "author": "telan <telanflow@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": "https://github.com/termlnk/termlnk.git",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "use:react18": "tsx ./scripts/react-version-manager.ts --react=18",
    "use:react19": "tsx ./scripts/react-version-manager.ts --react=19",
    "typecheck": "turbo typecheck",
    "test": "turbo test -- --passWithNoTests",
    "coverage": "turbo coverage -- --passWithNoTests",
    "build": "turbo build --concurrency=100% --filter=!./internal/* --filter=!./apps/*",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "release-it --preReleaseId=beta"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@release-it-plugins/workspaces": "^5.0.3",
    "@release-it/conventional-changelog": "^11.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@termlnk/shared": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260504.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "extract-changelog-release": "^1.0.2",
    "fs-extra": "^11.3.4",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "release-it": "^19.2.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.9",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
