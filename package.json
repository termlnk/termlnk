{
  "name": "@termlnk/termlnk",
  "type": "module",
  "version": "0.3.4",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": "https://github.com/termlnk/termlnk.git",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "use:react18": "tsx ./scripts/react-version-manager.ts --react=18",
    "use:react19": "tsx ./scripts/react-version-manager.ts --react=19",
    "typecheck": "turbo typecheck",
    "test": "turbo test -- --passWithNoTests",
    "coverage": "turbo coverage -- --passWithNoTests",
    "build": "turbo build --concurrency=100% --filter=!./internal/* --filter=!./apps/*",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "release-it --preReleaseId=beta"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint-react/eslint-plugin": "^5.12.0",
    "@release-it-plugins/workspaces": "^6.0.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@termlnk/shared": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "extract-changelog-release": "^1.0.2",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "release-it": "^19.2.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
