# termlnk-web environment variables.
# Dev: copy to `.env.local` (gitignored); loaded by bin/dev.js.
# Prod: inject via systemd EnvironmentFile / k8s envFrom / docker-compose env.

# ----------------------------------------------------------------------------
# Master password (REQUIRED)
# ----------------------------------------------------------------------------
# Derives the vault master key + access verifier (Argon2id). Server-side only;
# never sent to the browser.
# WARNING: rotating after the vault exists makes stored credentials unreadable.

TERMLNK_MASTER_PASSWORD=change-me-to-a-strong-passphrase

# ----------------------------------------------------------------------------
# HTTP / TLS (optional)
# ----------------------------------------------------------------------------

# TERMLNK_WEB_PORT=3000
# TERMLNK_WEB_HOST=127.0.0.1                    # 0.0.0.0 only when this process terminates TLS

# Direct TLS termination (omit when a reverse proxy handles TLS).
# TERMLNK_WEB_TLS_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
# TERMLNK_WEB_TLS_KEY=/etc/letsencrypt/live/example.com/privkey.pem

# SPA dist/. Docker bakes in /app/apps/web/renderer/dist; unset in dev (Vite serves it).
# TERMLNK_WEB_STATIC_ROOT=/app/apps/web/renderer/dist

# ----------------------------------------------------------------------------
# Vault / data paths (optional, default ~/.config/termlnk-web)
# ----------------------------------------------------------------------------

# TERMLNK_WEB_CONFIG_DIR=/data
# TERMLNK_WEB_DB_PATH=/data/termlnk-web.db
# TERMLNK_WEB_MIGRATIONS_DIR=/app/packages/database/src/migrations
# TERMLNK_WEB_BUNDLED_SKILLS_DIR=/app/packages/agent-core/src/bundled-skills
# TERMLNK_WEB_USER_SKILLS_DIR=/data/skills
# TERMLNK_WEB_HOOK_CLI_DIR=/app/packages/agent-hook-cli/src

# ----------------------------------------------------------------------------
# Cloud sync (optional)
# ----------------------------------------------------------------------------
# Point to a termlnk-server to sync vault across desktop / web / mobile.
# Unset = fully local. URL must include scheme.
# TERMLNK_CLOUD_BASE_URL=https://sync.termlnk.cloud
