# termlnk-web environment variables.
#
# For local dev, copy this file to `.env.local` (gitignored) and fill in real
# values. The dev bootstrap (apps/web/server/bin/dev.js) loads `.env.local`
# automatically before starting Vite + main.ts. For production deployments,
# wire these as docker secrets / systemd EnvironmentFile / k8s secrets — see
# apps/web/docker-compose.yml and docs/agent/termlnk-web-self-hosting.md.

# ----------------------------------------------------------------------------
# Master password (REQUIRED)
# ----------------------------------------------------------------------------
# The deployer-supplied secret used to derive the vault master key + access
# verifier (Argon2id; architecture decision Δ30). The browser never sees this
# value — it only ever lives in the server process memory.
#
# Pick exactly ONE of TERMLNK_MASTER_PASSWORD or TERMLNK_MASTER_PASSWORD_FILE.
# In production, prefer the file form combined with docker secrets so the
# secret never appears on the process command line / `ps` output.
#
# WARNING: rotating this password while a vault already exists makes the
# previously-stored credentials unreadable (same semantics as Bitwarden).
# Pick one strong value and keep it.

TERMLNK_MASTER_PASSWORD=change-me-to-a-strong-passphrase
# TERMLNK_MASTER_PASSWORD_FILE=/run/secrets/master_password

# ----------------------------------------------------------------------------
# HTTP / TLS surface (optional — sensible defaults baked in)
# ----------------------------------------------------------------------------

# Port the Node tRPC server binds to. Default: 3000.
# TERMLNK_WEB_PORT=3000

# Host interface to bind. Default: 127.0.0.1 (loopback). Recommended for
# production — terminate TLS in caddy / nginx in front and reverse-proxy to
# this loopback. Use 0.0.0.0 only if the container itself terminates TLS.
# TERMLNK_WEB_HOST=127.0.0.1

# Direct TLS termination (skip if a reverse proxy is doing TLS).
# TERMLNK_WEB_TLS_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
# TERMLNK_WEB_TLS_KEY=/etc/letsencrypt/live/example.com/privkey.pem

# Path to the SPA `dist/` produced by `apps/web/renderer pnpm build`. The
# Docker image bakes in /app/apps/web/renderer/dist; in dev the SPA is served
# by the Vite dev server (5179) so this stays unset.
# TERMLNK_WEB_STATIC_ROOT=/app/apps/web/renderer/dist

# ----------------------------------------------------------------------------
# Vault / data paths (optional — default to ~/.config/termlnk-web)
# ----------------------------------------------------------------------------

# Root directory holding the SQLite vault, derived-key cache, user skills.
# TERMLNK_WEB_CONFIG_DIR=/data

# Override the SQLite file location.
# TERMLNK_WEB_DB_PATH=/data/termlnk-web.db

# Drizzle migrations folder. In dev defaults to the workspace source. The
# Docker image bakes this in via the runtime stage.
# TERMLNK_WEB_MIGRATIONS_DIR=/app/packages/database/src/migrations

# Bundled / user skill directories.
# TERMLNK_WEB_BUNDLED_SKILLS_DIR=/app/packages/agent-core/src/bundled-skills
# TERMLNK_WEB_USER_SKILLS_DIR=/data/skills

# CLI hook helper sources (copied into ~/.config/termlnk-web/bin at startup).
# TERMLNK_WEB_HOOK_CLI_DIR=/app/packages/agent-hook-cli/src

# ----------------------------------------------------------------------------
# Cloud sync (optional)
# ----------------------------------------------------------------------------
# Connect this self-hosted termlnk-web to a public termlnk-server instance so
# the user's vault syncs across desktop / web / mobile. Leave unset to run
# fully local (no sync). The URL must include scheme (https / http for dev).
# TERMLNK_CLOUD_BASE_URL=https://sync.termlnk.cloud
