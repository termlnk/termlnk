{
  "name": "@termlnk/web-app-server",
  "type": "module",
  "version": "0.1.1",
  "private": true,
  "description": "termlnk-web server entrypoint — Node.js + tRPC standalone HTTP/WS adapter (P7.3)",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "main": "./src/main.ts",
  "scripts": {
    "predev": "node ./scripts/ensure-node-abi.mjs",
    "dev": "node ./bin/dev.js",
    "build": "vite build",
    "prestart": "node ./scripts/ensure-node-abi.mjs",
    "start": "node ./dist/main.mjs",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@termlnk/agent-core": "workspace:*",
    "@termlnk/auth": "workspace:*",
    "@termlnk/auth-core": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/database": "workspace:*",
    "@termlnk/extension-core": "workspace:*",
    "@termlnk/network": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-server": "workspace:*",
    "@termlnk/shared-terminal": "workspace:*",
    "@termlnk/shared-terminal-core": "workspace:*",
    "@termlnk/sync": "workspace:*",
    "@termlnk/sync-core": "workspace:*",
    "@termlnk/web-server": "workspace:*"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.14"
  }
}
