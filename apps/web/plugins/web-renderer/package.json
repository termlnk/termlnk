{
  "name": "@termlnk/web-renderer",
  "version": "0.0.1",
  "private": true,
  "description": "Web-private renderer plugin: tRPC httpBatchLink + wsLink wiring and web placeholders for Electron-only DI tokens. Not published — consumed only by apps/web/renderer.",
  "author": "telan <telanflow@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "main": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/core": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/network": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/sftp-ui": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/network": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/sftp-ui": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "@trpc/client": "^11.16.0",
    "lucide-react": "^1.14.0"
  },
  "devDependencies": {
    "@termlnk/rpc-server": "workspace:*",
    "@termlnk/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
