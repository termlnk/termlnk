# termlnk-web deploy configuration
# Copy to .env and edit before running install.sh or docker compose up.
#
# install.sh generates this file automatically — manual editing is only
# needed for advanced setups or post-install tuning.

# ---------------------------------------------------------------------------
# Image
# ---------------------------------------------------------------------------

# Image tag to pull from GHCR. Pin to a specific version (e.g. v0.1.0) to
# avoid silently pulling breaking changes.
TERMLNK_WEB_TAG=latest

# ---------------------------------------------------------------------------
# TLS (optional — requires the `tls` compose profile)
# ---------------------------------------------------------------------------

# Public domain for Caddy auto-HTTPS (Let's Encrypt). Leave empty for
# HTTP-only deployments behind your own reverse proxy.
TERMLNK_WEB_DOMAIN=

# ---------------------------------------------------------------------------
# Demo mode (optional)
# ---------------------------------------------------------------------------

# Set to "true" to bypass browser login and show decorative macOS traffic
# lights. Intended for the website live embed only — never enable on a
# deployment that stores real SSH credentials.
TERMLNK_WEB_DEMO=

# ---------------------------------------------------------------------------
# Cloud sync (optional)
# ---------------------------------------------------------------------------

# Connect to a termlnk-server instance for E2EE vault sync across devices.
# Example: https://cloud.termlnk.com/v1
TERMLNK_CLOUD_BASE_URL=
