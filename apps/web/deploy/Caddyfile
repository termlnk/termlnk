# Caddy reverse proxy for termlnk-web with automatic HTTPS (Let's Encrypt).
# Activated by the `tls` compose profile:
#   TERMLNK_WEB_DOMAIN=my.example.com docker compose --profile tls up -d
#
# Caddy v2 transparently proxies the tRPC WebSocket upgrade (/trpc-ws) and sets
# X-Forwarded-Proto: https, which is what makes web-server flag the session
# cookie Secure (see packages/web-server/src/trpc/auth-routes.ts).
{$TERMLNK_WEB_DOMAIN} {
	encode zstd gzip

	# Terminal subscriptions stay open for hours; lift the proxy stream timeouts.
	reverse_proxy termlnk-web:3000 {
		flush_interval -1
	}
}
