{
  "name": "@termlnk/react-native-russh",
  "version": "0.0.1",
  "private": true,
  "description": "Self-vendored React Native binding for Rust russh + russh-sftp via uniffi-bindgen-react-native. Replaces the NMSSH/JSch bridge in termlnk-mobile.",
  "author": "telan <telanflow@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "main": "./src/api/index.ts",
  "types": "./src/api/index.ts",
  "exports": {
    ".": "./src/api/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "android",
    "ios",
    "cpp",
    "rust",
    "*.podspec",
    "react-native.config.js",
    "*.md",
    "ubrn.config.yaml",
    "tsconfig*.json",
    "LICENSE"
  ],
  "scripts": {
    "build:ios": "ubrn build ios --and-generate --release",
    "build:android": "ubrn build android --and-generate --release",
    "build:native": "tsx scripts/native-build.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf lib android ios cpp src/generated rust/target"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-native": "~0.83.9"
  },
  "dependencies": {
    "uniffi-bindgen-react-native": "github:jhugman/uniffi-bindgen-react-native#62c91bcce60ca9bbee7269820cc79a9680cb908b"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "typescript": "^6.0.3"
  },
  "codegenConfig": {
    "name": "RusshSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.termlnk.russh"
    }
  }
}
