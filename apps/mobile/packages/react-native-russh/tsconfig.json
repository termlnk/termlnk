{
  "extends": "@termlnk/shared/tsconfig/base",
  "compilerOptions": {
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["react", "react-native"],
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*", "scripts/**/*", "*.ts"]
}
