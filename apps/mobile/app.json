{
  "expo": {
    "name": "Termlnk",
    "slug": "termlnk",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "termlnk",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.termlnk.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photos to attach images to messages"
      }
    },
    "android": {
      "package": "io.termlnk.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      }
    },
    "plugins": [
      ["expo-router", { "root": "./src/router" }],
      "expo-secure-store",
      "expo-local-authentication",
      "expo-document-picker",
      "expo-file-system",
      "expo-image-picker",
      "expo-notifications",
      "react-native-libsodium",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "buildReactNativeFromSource": true,
            "useHermesV1": false
          }
        }
      ],
      "./config-plugins/with-ios-hermes-v1-env.cjs"
    ],
    "autolinking": {
      "searchPaths": [
        "../../node_modules",
        "./node_modules"
      ]
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "PROVIDE_VIA_EAS_PROJECT_INIT"
      }
    }
  }
}
