# Termlnk Desktop - development environment overrides
#
# Copy this file to `.env` (or `.env.local`) and fill in the values you need.
# electron-vite loads `.env*` files automatically in dev. Variables defined here
# are exposed via `process.env.*` in the main process at runtime.
#
# Packaged release builds IGNORE this file - cloud endpoints baked into the
# binary are sourced from `PRODUCTION_CLOUD_BASE_URL` in apps/desktop/main/src/bootstrap.ts.

# Cloud auth/sync root. MUST include the API version prefix the server mounts on.
# Local dev (termlnk-server defaults): http://127.0.0.1:4000/v1
# Staging:                              https://staging.cloud.termlnk.io/v1
# Leave unset to disable cloud features - AuthGate falls back to the "unavailable" placeholder.
TERMLNK_CLOUD_BASE_URL=http://127.0.0.1:4000/v1

# Updater mock (optional). Accepts: normal | check-error | download-error | no-update
# Only honored in unpackaged dev builds. See apps/desktop/plugins/electron-main/src/services/updater/mock-updater.service.ts.
# TERMLNK_MOCK_UPDATER=normal
