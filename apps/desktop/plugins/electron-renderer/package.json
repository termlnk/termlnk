{
  "name": "@termlnk/electron-renderer",
  "version": "0.1.1",
  "private": true,
  "description": "Electron renderer plugin (tRPC IPC client, window manager wrapper, PTY wrapper, header).",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./locale/*": "./src/locale/*.ts"
  },
  "main": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/settings-ui": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@janwirth/electron-trpc-link": "11.1.2-bugfix-2",
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/settings-ui": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "@trpc/client": "^11.17.0",
    "lucide-react": "^1.16.0"
  },
  "devDependencies": {
    "@termlnk/electron-main": "workspace:*",
    "@termlnk/rpc-server": "workspace:*",
    "@termlnk/shared": "workspace:*",
    "electron": "41.7.1",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
