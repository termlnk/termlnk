    "@termlnk/rpc-server": "workspace:*",
    "@termlnk/sync": "workspace:*",
    "electron": "40.9.2",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.75.5",
    "@janwirth/electron-trpc-link": "11.1.2-bugfix-2",
