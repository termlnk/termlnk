{
  "name": "@termlnk/electron-main",
  "version": "0.0.0",
  "private": false,
  "author": "telan <telanflow@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/database": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/island": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-server": "workspace:*",
    "electron": "40.9.2",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@janwirth/electron-trpc-link": "11.1.2-bugfix-2",
    "@mariozechner/pi-agent-core": "^0.72.0",
    "@sinclair/typebox": "^0.34.49",
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/database": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/island": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-server": "workspace:*",
    "@trpc/server": "^11.16.0",
    "electron-updater": "^6.8.3",
    "semver": "^7.7.4",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@termlnk/macos-utils": "workspace:*"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "@types/semver": "^7.7.1",
    "electron": "41.5.0",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
