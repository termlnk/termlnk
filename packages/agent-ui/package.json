{
  "name": "@termlnk/agent-ui",
  "version": "0.3.3",
  "private": false,
  "description": "Agent UI components for termlnk - provider configuration and model selection",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./global.css": "./src/global.css",
    "./locale/*": "./src/locale/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./locale/*": {
        "import": "./lib/es/locale/*.js",
        "require": "./lib/cjs/locale/*.js",
        "types": "./lib/types/locale/*.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/extension": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/settings-ui": "workspace:*",
    "@termlnk/themes": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.23.0",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/extension": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/settings-ui": "workspace:*",
    "@termlnk/themes": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "lucide-react": "^1.23.0",
    "remend": "^1.0.1",
    "streamdown": "^1.6.11",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "@types/hast": "^3.0.4",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
