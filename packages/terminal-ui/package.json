{
  "name": "@termlnk/terminal-ui",
  "version": "0.2.0",
  "private": false,
  "description": "Terminal UI library for termlnk",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./locale/*": "./src/locale/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./locale/*": {
        "import": "./lib/es/locale/*.js",
        "require": "./lib/cjs/locale/*.js",
        "types": "./lib/types/locale/*.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/shared-terminal": "workspace:*",
    "@termlnk/terminal": "workspace:*",
    "@termlnk/themes": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "react-dom": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "react-resizable-panels": "^4.11.2",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@headless-tree/core": "^1.7.0",
    "@headless-tree/react": "^1.7.0",
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/shared-terminal": "workspace:*",
    "@termlnk/terminal": "workspace:*",
    "@termlnk/themes": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "@xterm/addon-attach": "^0.13.0-beta.276",
    "@xterm/addon-fit": "^0.12.0-beta.276",
    "@xterm/addon-image": "^0.10.0-beta.276",
    "@xterm/addon-ligatures": "^0.11.0-beta.276",
    "@xterm/addon-progress": "^0.3.0-beta.276",
    "@xterm/addon-search": "^0.17.0-beta.276",
    "@xterm/addon-serialize": "^0.15.0-beta.276",
    "@xterm/addon-unicode-graphemes": "^0.5.0-beta.276",
    "@xterm/addon-unicode11": "^0.10.0-beta.276",
    "@xterm/addon-web-fonts": "^0.2.0-beta.190",
    "@xterm/addon-web-links": "^0.13.0-beta.276",
    "@xterm/addon-webgl": "^0.20.0-beta.275",
    "@xterm/xterm": "^6.1.0-beta.276",
    "filesize": "^11.0.17",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "react-resizable-panels": "^4.11.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
