{
  "name": "@termlnk/rpc-server",
  "version": "0.0.2",
  "private": false,
  "description": "RPC server routers and plugin for termlnk",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/agent": "workspace:*",
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/database": "workspace:*",
    "@termlnk/extension": "workspace:*",
    "@termlnk/extension-core": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/shared-terminal": "workspace:*",
    "@termlnk/sync": "workspace:*",
    "@termlnk/terminal": "workspace:*",
    "rxjs": ">=7.0.0",
    "socks": "^2.8.9",
    "ssh2": "^1.17.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@termlnk/agent": "workspace:*",
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/database": "workspace:*",
    "@termlnk/extension": "workspace:*",
    "@termlnk/extension-core": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/shared-terminal": "workspace:*",
    "@termlnk/sync": "workspace:*",
    "@termlnk/terminal": "workspace:*",
    "@trpc/server": "^11.17.0",
    "node-pty": "^1.1.0",
    "socks": "^2.8.9",
    "ssh2": "^1.17.0",
    "trzsz": "^1.1.6",
    "uuid": "^14.0.0",
    "zmodem2": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "@types/ssh2": "^1.15.5",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
