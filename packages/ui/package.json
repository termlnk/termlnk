{
  "name": "@termlnk/ui",
  "version": "0.3.4",
  "private": false,
  "description": "UI library for termlnk",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./locale/*": "./src/locale/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./locale/*": {
        "import": "./lib/es/locale/*.js",
        "require": "./lib/cjs/locale/*.js",
        "types": "./lib/types/locale/*.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/themes": "workspace:*",
    "lucide-react": "^1.25.0",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "react-dom": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "react-resizable-panels": "^4.12.1",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/themes": "workspace:*",
    "emoji-mart": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.3.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
