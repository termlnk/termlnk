{
  "name": "@termlnk/electron-renderer",
  "version": "0.0.0",
  "private": false,
  "author": "telan <telanflow@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./locale/*": "./src/locale/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./locale/*": {
        "import": "./lib/es/locale/*.js",
        "require": "./lib/cjs/locale/*.js",
        "types": "./lib/types/locale/*.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "lucide-react": "^1.11.0",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@janwirth/electron-trpc-link": "11.1.2-bugfix-2",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "@trpc/client": "^11.16.0",
    "lucide-react": "^1.11.0"
  },
  "devDependencies": {
    "@termlnk/electron-main": "workspace:*",
    "@termlnk/rpc-server": "workspace:*",
    "@termlnk/shared": "workspace:*",
    "electron": "41.5.0",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
