{
  "name": "@termlnk/snippet-ui",
  "version": "0.3.2",
  "private": false,
  "description": "Snippet UI plugin for termlnk - snippet management panel, editor, and execution",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./locale/*": "./src/locale/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./locale/*": {
        "import": "./lib/es/locale/*.js",
        "require": "./lib/cjs/locale/*.js",
        "types": "./lib/types/locale/*.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/snippet": "workspace:*",
    "@termlnk/terminal": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "lucide-react": "^1.21.0",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@headless-tree/core": "^1.7.0",
    "@headless-tree/react": "^1.7.0",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/snippet": "workspace:*",
    "@termlnk/terminal": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
