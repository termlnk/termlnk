{
  "name": "@termlnk/agent-core",
  "version": "0.0.0",
  "private": false,
  "description": "Agent core services for termlnk - AI agent, MCP server/client, and skill management implementations",
  "author": "telan <telanflow@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "main": "./src/index.ts",
  "types": "./lib/types/index.d.ts",
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/database": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "rxjs": ">=7.0.0",
    "socks": "^2.8.7"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.0",
    "@mariozechner/pi-ai": "^0.73.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/database": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "partial-json": "^0.1.7",
    "socks": "^2.8.8",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@termlnk/macos-utils": "workspace:*"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
