{
  "name": "@termlnk/web-renderer",
  "version": "0.3.2",
  "private": true,
  "description": "Web-private renderer plugin: tRPC httpBatchLink + wsLink wiring and web placeholders for Electron-only DI tokens. Not published — consumed only by apps/web/renderer.",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "main": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "termlnk-cli build"
  },
  "peerDependencies": {
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/network": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/sftp-ui": "workspace:*",
    "@termlnk/shared-terminal": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "lucide-react": "^1.21.0",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@termlnk/auth": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/electron": "workspace:*",
    "@termlnk/network": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/sftp-ui": "workspace:*",
    "@termlnk/shared-terminal": "workspace:*",
    "@termlnk/ui": "workspace:*",
    "@trpc/client": "^11.17.0",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@termlnk/rpc-server": "workspace:*",
    "@termlnk/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "main": "./lib/es/index.js",
    "module": "./lib/es/index.js",
    "exports": {
      ".": {
        "import": "./lib/es/index.js",
        "require": "./lib/cjs/index.js",
        "types": "./lib/types/index.d.ts"
      },
      "./*": {
        "import": "./lib/es/*",
        "require": "./lib/cjs/*",
        "types": "./lib/types/index.d.ts"
      },
      "./lib/*": "./lib/*"
    }
  }
}
