{
  "name": "@termlnk/react-native-russh",
  "version": "0.3.4",
  "private": true,
  "description": "Self-vendored React Native binding for Rust russh + russh-sftp via uniffi-bindgen-react-native. Replaces the NMSSH/JSch bridge in termlnk-mobile.",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "homepage": "https://github.com/termlnk/termlnk#readme",
  "repository": {
    "url": "git+https://github.com/termlnk/termlnk.git",
    "type": "git"
  },
  "exports": {
    ".": "./src/api/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/api/index.ts",
  "types": "./src/api/index.ts",
  "files": [
    "*.md",
    "*.podspec",
    "LICENSE",
    "android",
    "cpp",
    "ios",
    "react-native.config.js",
    "rust",
    "src",
    "tsconfig*.json",
    "ubrn.config.yaml"
  ],
  "scripts": {
    "build:ios": "ubrn build ios --and-generate --release",
    "build:android": "ubrn build android --and-generate --release",
    "build:native": "tsx scripts/native-build.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf lib android ios cpp src/generated rust/target"
  },
  "peerDependencies": {
    "react": "^19.2.8",
    "react-native": "^0.85.3"
  },
  "dependencies": {
    "@ubjs/core": "0.31.0-3",
    "uniffi-bindgen-react-native": "0.31.0-3"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "typescript": "^6.0.3"
  },
  "codegenConfig": {
    "name": "RusshSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.termlnk.russh"
    }
  }
}
