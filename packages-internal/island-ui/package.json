{
  "name": "@termlnk/island-ui",
  "version": "0.3.3",
  "private": true,
  "description": "Dynamic Island UI — macOS notch overlay with session status and permission approval.",
  "author": "telan <telanflow@gmail.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "url": "https://github.com/termlnk/termlnk",
    "type": "git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./global.css": "./src/global.css",
    "./locale/*": "./src/locale/*.ts"
  },
  "main": "./src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/island": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/settings-ui": "workspace:*",
    "lucide-react": "^1.21.0",
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@termlnk/agent": "workspace:*",
    "@termlnk/core": "workspace:*",
    "@termlnk/design": "workspace:*",
    "@termlnk/island": "workspace:*",
    "@termlnk/rpc": "workspace:*",
    "@termlnk/rpc-client": "workspace:*",
    "@termlnk/settings-ui": "workspace:*",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@termlnk/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
