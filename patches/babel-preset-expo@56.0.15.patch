-                        require('@babel/plugin-transform-typescript'),
-                        {
-                            isTSX: false,
-                            allowNamespaces: true,
-                        },
-                    ],
-                ],
+                test: (f) => isTypeScriptSource(f) && !isAppSource(f),
+                plugins: [[transformTypeScript, { isTSX: false, allowNamespaces: true }]],
             },
             {
-                test: isTSXSource,
-                plugins: [
-                    [
-                        require('@babel/plugin-transform-typescript'),
