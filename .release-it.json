{
  "git": {
    "commitMessage": "release(desktop): v${version}",
    "tagName": "v${version}",
    "requireBranch": "main"
  },
  "github": {
    "release": false,
    "releaseName": "Desktop v${version}",
    "draft": true
  },
  "npm": false,
  "hooks": {
    "after:@release-it/conventional-changelog:beforeRelease": [
      "node apps/desktop/scripts/extract-release-notes.mjs --version ${version}",
      "git add apps/desktop/build/release-notes.md"
    ]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "docs/CHANGELOG.md",
      "ignoreRecommendedBump": true
    },
    "@release-it-plugins/workspaces": {
      "skipChecks": true,
      "publish": false,
      "workspaces": [
        "packages/*",
        "internal/*",
        "apps/desktop",
        "apps/desktop/main",
        "apps/desktop/renderer",
        "packages-internal/*",
        "apps/web/server",
        "apps/web/renderer",
        "apps/mobile"
      ]
    }
  }
}
