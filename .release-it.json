{
  "git": {
    "commitMessage": "release(desktop): v${version}",
    "tagName": "v${version}",
    "requireBranch": "main"
  },
  "github": {
    "release": false,
    "releaseName": "Desktop v${version}",
    "draft": true
  },
  "npm": false,
  "hooks": {
    "after:bump": [
      "extract-changelog-release docs/CHANGELOG.md > apps/desktop/build/release-notes.md",
      "git add apps/desktop/build/release-notes.md"
    ]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "docs/CHANGELOG.md",
      "ignoreRecommendedBump": true
    },
    "@release-it-plugins/workspaces": {
      "skipChecks": true,
      "publish": false,
      "workspaces": [
        "packages/*",
        "internal/*",
        "apps/desktop",
        "apps/desktop/main",
        "apps/desktop/renderer",
        "apps/desktop/plugins/*",
        "apps/web/server",
        "apps/web/renderer",
        "apps/web/plugins/*",
        "apps/mobile",
        "apps/mobile/packages/*"
      ]
    }
  }
}
